<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.farmingdale.oopandjavafx.HelloController">

    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="New" onAction="#handleNew"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Exit" onAction="#handleExit"/>
                    </items>
                </Menu>

                <Menu text="Edit">
                    <items>
                        <MenuItem text="Delete" onAction="#handleDelete"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <TableView fx:id="tableView">
            <columns>
                <TableColumn fx:id="firstNameCol" text="First Name"/>
                <TableColumn fx:id="lastNameCol" text="Last Name"/>
                <TableColumn fx:id="ageCol" text="Age"/>
            </columns>
        </TableView>
    </center>

</BorderPane>